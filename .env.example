# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Google Gemini API (required for Antigravity Agent negotiation feature)
GEMINI_API_KEY=your-gemini-api-key

# Admin Credentials (change these in production!)
ADMIN_EMAIL=fd6016826@gmail.com
ADMIN_PASSWORD=admin_temp_change_me

# PayTech Configuration
PAYTECH_API_KEY=your-paytech-api-key
PAYTECH_API_SECRET=your-paytech-api-secret
# PAYTECH_ENV: 'test' pour le mode sandbox/test, ou 'prod' pour accepter les paiements réels
PAYTECH_ENV=prod
PAYTECH_IPN_URL=https://your-domain.vercel.app/api/payment/ipn
PAYTECH_SUCCESS_URL=https://la-brocant.vercel.app/profile?payment=success
PAYTECH_CANCEL_URL=https://la-brocant.vercel.app/profile?payment=cancel

# Application Environment
NODE_ENV=production
PORT=3000
