{
  "buildCommand": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --external:vite --external:esbuild --external:lightningcss --log-override:empty-import-meta=silent --outfile=server.cjs",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server.cjs",
      "maxDuration": 30
    }
  }
}

