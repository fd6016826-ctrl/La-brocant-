{
  "buildCommand": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --external:vite --external:esbuild --external:lightningcss --footer:js=\"module.exports = app;\" --log-override:empty-import-meta=silent --outfile=api/index.cjs",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.cjs": {
      "maxDuration": 30
    }
  }
}




